# Copy to the Droplet as /opt/tokenstats/.env (next to docker-compose.yml)
#   cp deploy/env.example .env && nano .env

# Hostnames for Caddy / Let's Encrypt (comma-separated list is OK)
# Examples:
#   DOMAIN=tokenstats.ai
#   DOMAIN=tokenstats.ai, www.tokenstats.ai
#   DOMAIN=tokenta.pe
#   DOMAIN=tokenstats.ai, tokenta.pe
DOMAIN=tokenstats.ai
# ACME registration email (Caddy / Let's Encrypt)
ACME_EMAIL=admin@tokenstats.ai

# App
TOKENSTATS_POLL_INTERVAL_SECS=60
TOKENSTATS_BTC_INTERVAL_SECS=60
TOKENSTATS_PERSIST_INTERVAL_SECS=30
RUST_LOG=info,tokenstats=info,tower_http=info

# Host port when NOT using Caddy profile (IP:8080 access)
TOKENSTATS_PUBLISH_PORT=8080
